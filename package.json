{
  "name": "pelu",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "npm run config:validate",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test:responsive": "playwright test",
    "test:responsive:update": "playwright test --update-snapshots",
    "test:media": "tsx --test tests/unit/media.test.ts",
    "test:installation": "tsx --test tests/unit/installation.test.ts",
    "config:validate": "node scripts/validate-installation.mjs",
    "config:validate:fixture": "node scripts/validate-installation.mjs tests/fixtures/installation.aurora.json tests/fixtures/installation.aurora.seed.json",
    "media:provision": "node scripts/provision-cloudflare-r2.mjs",
    "media:publish": "node scripts/publish-media.mjs",
    "perf:budgets": "node scripts/check-performance-budgets.mjs",
    "perf:lighthouse": "lhci autorun",
    "perf:lighthouse:mobile": "lhci autorun --config=lighthouserc.json",
    "perf:lighthouse:desktop": "lhci autorun --config=lighthouserc.desktop.json"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.22.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "radix-ui": "^1.6.2",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1090.0",
    "@axe-core/playwright": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.20.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "eslint": "^9.39.5",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.20.6",
    "typescript": "^5"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
