{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nox.local/schemas/installation-v1.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "tenant", "businessType", "localization", "brand", "seo", "domains", "contact", "location", "hours", "openingHours", "payments", "booking", "policies", "channels", "shop", "agent", "demo", "features", "content", "copy"],
  "properties": {
    "$schema": { "type": "string" },
    "schemaVersion": { "const": 1 },
    "tenant": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]{1,62}[a-z0-9]$" },
    "businessType": { "type": "string", "enum": ["hair_salon", "barbershop", "beauty_salon", "appointments_business"] },
    "localization": {
      "type": "object", "additionalProperties": false,
      "required": ["language", "locale", "timezone", "countryCode", "countryName", "currency"],
      "properties": {
        "language": { "type": "string", "pattern": "^[a-z]{2}$" },
        "locale": { "type": "string", "pattern": "^[a-z]{2}-[A-Z]{2}$" },
        "timezone": { "type": "string", "minLength": 3 },
        "countryCode": { "type": "string", "pattern": "^[A-Z]{2}$" },
        "countryName": { "type": "string", "minLength": 2, "maxLength": 80 },
        "currency": {
          "type": "object", "additionalProperties": false,
          "required": ["code", "symbol", "fractionDigits"],
          "properties": {
            "code": { "type": "string", "pattern": "^[A-Z]{3}$" },
            "symbol": { "type": "string", "minLength": 1, "maxLength": 4 },
            "fractionDigits": { "type": "integer", "minimum": 0, "maximum": 3 }
          }
        }
      }
    },
    "brand": {
      "type": "object", "additionalProperties": false,
      "required": ["name", "shortName", "establishedYear", "tagline", "description", "theme"],
      "properties": {
        "name": { "type": "string", "minLength": 2, "maxLength": 80 },
        "shortName": { "type": "string", "minLength": 1, "maxLength": 24 },
        "establishedYear": { "type": "integer", "minimum": 1800, "maximum": 2200 },
        "tagline": { "type": "string", "minLength": 2, "maxLength": 100 },
        "description": { "type": "string", "minLength": 40, "maxLength": 320 },
        "theme": {
          "type": "object", "additionalProperties": false,
          "required": ["primary", "background", "foreground", "card"],
          "properties": {
            "primary": { "$ref": "#/$defs/color" },
            "background": { "$ref": "#/$defs/color" },
            "foreground": { "$ref": "#/$defs/color" },
            "card": { "$ref": "#/$defs/color" }
          }
        }
      }
    },
    "seo": {
      "type": "object", "additionalProperties": false,
      "required": ["keywords", "priceRange"],
      "properties": {
        "keywords": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "minLength": 2, "maxLength": 80 } },
        "priceRange": { "type": "string", "minLength": 1, "maxLength": 8 }
      }
    },
    "domains": {
      "type": "object", "additionalProperties": false,
      "required": ["site", "shop"],
      "properties": { "site": { "type": "string", "format": "uri" }, "shop": { "type": "string", "format": "uri" } }
    },
    "contact": {
      "type": "object", "additionalProperties": false,
      "required": ["phoneDisplay", "email"],
      "properties": { "phoneDisplay": { "type": "string", "minLength": 7 }, "email": { "type": "string", "format": "email" } }
    },
    "location": {
      "type": "object", "additionalProperties": false,
      "required": ["city", "region", "address", "streetAddress", "postalCode", "neighborhood", "latitude", "longitude", "mapsQuery", "directions", "mapsEmbed"],
      "properties": {
        "city": { "type": "string", "minLength": 2 }, "region": { "type": "string", "minLength": 2 }, "address": { "type": "string", "minLength": 4 },
        "streetAddress": { "type": "string", "minLength": 4 }, "postalCode": { "type": "string", "minLength": 2 },
        "neighborhood": { "type": "string" }, "latitude": { "type": "number", "minimum": -90, "maximum": 90 },
        "longitude": { "type": "number", "minimum": -180, "maximum": 180 }, "mapsQuery": { "type": "string", "minLength": 2 },
        "directions": { "type": "string", "minLength": 2, "maxLength": 320 },
        "mapsEmbed": { "type": "string", "format": "uri" }
      }
    },
    "hours": { "type": "array", "minItems": 1, "items": { "type": "object", "additionalProperties": false, "required": ["day", "time"], "properties": { "day": { "type": "string", "minLength": 2 }, "time": { "type": "string", "minLength": 2 } } } },
    "openingHours": { "type": "array", "items": { "type": "object", "additionalProperties": false, "required": ["days", "opens", "closes"], "properties": { "days": { "type": "array", "minItems": 1, "uniqueItems": true, "items": { "type": "string", "enum": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"] } }, "opens": { "type": "string", "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$" }, "closes": { "type": "string", "pattern": "^(?:[01]\\d|2[0-3]):[0-5]\\d$" } } } },
    "payments": {
      "type": "object", "additionalProperties": false,
      "required": ["methods", "display", "allowPayAtStore", "allowOnline"],
      "properties": {
        "methods": { "type": "array", "uniqueItems": true, "items": { "type": "string", "enum": ["cash", "bank_transfer", "card", "mercado_pago"] } },
        "display": { "type": "string", "minLength": 2 }, "allowPayAtStore": { "type": "boolean" }, "allowOnline": { "type": "boolean" }
      }
    },
    "booking": {
      "type": "object", "additionalProperties": false,
      "required": ["enabled", "path", "slotGranularityMinutes", "minimumLeadMinutes", "maximumDaysAhead"],
      "properties": {
        "enabled": { "type": "boolean" }, "path": { "type": "string", "pattern": "^/" },
        "slotGranularityMinutes": { "type": "integer", "minimum": 5, "maximum": 240 },
        "minimumLeadMinutes": { "type": "integer", "minimum": 0, "maximum": 10080 },
        "maximumDaysAhead": { "type": "integer", "minimum": 1, "maximum": 730 }
      }
    },
    "policies": {
      "type": "object", "additionalProperties": false,
      "required": ["cancellationNoticeMinutes", "cancellationNotes", "arrivalRecommendation"],
      "properties": {
        "cancellationNoticeMinutes": { "type": "integer", "minimum": 0, "maximum": 10080 },
        "cancellationNotes": { "type": "string", "minLength": 2, "maxLength": 320 },
        "arrivalRecommendation": { "type": "string", "minLength": 2, "maxLength": 320 }
      }
    },
    "channels": {
      "type": "object", "additionalProperties": false,
      "required": ["whatsapp", "instagram", "telegram", "email"],
      "properties": {
        "whatsapp": { "$ref": "#/$defs/channel" }, "instagram": { "$ref": "#/$defs/socialChannel" },
        "telegram": { "$ref": "#/$defs/channel" }, "email": { "$ref": "#/$defs/channel" }
      }
    },
    "shop": { "type": "object", "additionalProperties": false, "required": ["enabled", "url", "pickupOnly"], "properties": { "enabled": { "type": "boolean" }, "url": { "type": "string", "format": "uri" }, "pickupOnly": { "type": "boolean" } } },
    "agent": { "type": "object", "additionalProperties": false, "required": ["enabled", "name", "tone", "scope"], "properties": { "enabled": { "type": "boolean" }, "name": { "type": "string", "minLength": 1 }, "tone": { "type": "string", "minLength": 2 }, "scope": { "type": "array", "uniqueItems": true, "items": { "type": "string", "enum": ["appointments", "business_information", "products", "orders", "payments"] } } } },
    "demo": { "type": "object", "additionalProperties": false, "required": ["defaultBarberSlug"], "properties": { "defaultBarberSlug": { "type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$" } } },
    "features": { "type": "object", "additionalProperties": false, "required": ["customerPortal", "barberPortal", "newsletter", "campaigns", "onlinePayments"], "properties": { "customerPortal": { "type": "boolean" }, "barberPortal": { "type": "boolean" }, "newsletter": { "type": "boolean" }, "campaigns": { "type": "boolean" }, "onlinePayments": { "type": "boolean" } } },
    "content": {
      "type": "object", "additionalProperties": false,
      "required": ["heroHighlights", "servicesIntro", "teamIntro", "galleryIntro", "about"],
      "properties": {
        "heroHighlights": { "type": "array", "minItems": 1, "maxItems": 8, "items": { "type": "string", "minLength": 2, "maxLength": 40 } },
        "servicesIntro": { "type": "string", "minLength": 10, "maxLength": 320 },
        "teamIntro": { "type": "string", "minLength": 10, "maxLength": 320 },
        "galleryIntro": { "type": "string", "minLength": 10, "maxLength": 320 },
        "about": {
          "type": "object", "additionalProperties": false,
          "required": ["lead", "body", "values"],
          "properties": {
            "lead": { "type": "string", "minLength": 10, "maxLength": 320 },
            "body": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "type": "string", "minLength": 10, "maxLength": 640 } },
            "values": { "type": "array", "minItems": 1, "maxItems": 6, "items": { "type": "object", "additionalProperties": false, "required": ["title", "text"], "properties": { "title": { "type": "string", "minLength": 2, "maxLength": 80 }, "text": { "type": "string", "minLength": 10, "maxLength": 320 } } } }
          }
        }
      }
    },
    "copy": { "type": "object", "additionalProperties": false, "required": ["bookingCta", "demoBanner", "newsletterTitle"], "properties": { "bookingCta": { "type": "string", "minLength": 2 }, "demoBanner": { "type": "string", "minLength": 2 }, "newsletterTitle": { "type": "string", "minLength": 2 } } }
  },
  "$defs": {
    "color": { "type": "string", "pattern": "^#[0-9a-fA-F]{6}$" },
    "channel": { "type": "object", "additionalProperties": false, "required": ["enabled", "address"], "properties": { "enabled": { "type": "boolean" }, "address": { "type": "string" } } },
    "socialChannel": { "type": "object", "additionalProperties": false, "required": ["enabled", "address", "url"], "properties": { "enabled": { "type": "boolean" }, "address": { "type": "string" }, "url": { "type": "string", "format": "uri" } } }
  }
}
